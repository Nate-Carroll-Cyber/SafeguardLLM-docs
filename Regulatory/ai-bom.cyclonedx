        {"name": "vectorDimension", "value": "768"},
        {"name": "egressPolicy", "value": "local/private-network only"},
        {"name": "weights", "value": "open-weight; UNVERIFIED (no checksum in repo)"}
      ]
    },
    {
      "type": "data",
      "name": "core pgvector seed corpus",
      "version": "core-2026-05-10-latest",
      "description": "Reviewed-ADVERSARIAL instruction fingerprints/embeddings. 319 records / 611 chunks / 768-dim. Source controlled-prompt-review.",
      "hashes": [
        {"alg": "SHA-256", "content": "06cb8e18fcebd73ea2933d7a1c3e71979ff8a396fd8531617a2a1509297e5cd5"},
