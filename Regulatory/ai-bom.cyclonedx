      "properties": [{"name": "runtimeUser", "value": "non-root node via su-exec 0.2-r3"}]
    }
  ],
  "services": [
    {
      "name": "counter-spy-backend",
      "endpoints": ["/v1/intercept", "/v1/translate", "/v1/instruction-monitor/reviewed-adversarial", "/v1/ctf/sam-spade/*", "/healthz"],
      "authenticated": true,
      "x-trust-boundary": "Owns provider secrets; browser cannot override provider config",
      "data": [{"classification": "redacted-prompts + SHA-256 hashes"}],
      "properties": [
        {"name": "auth", "value": "shared static bearer token (INTERCEPT_BEARER_TOKEN); JWT/OIDC NOT implemented"},
        {"name": "port", "value": "18080"}
      ]
    },
    {
      "name": "Google Firestore",
      "x-trust-boundary": "Google Cloud US-West2",
      "data": [{"classification": "audit logs, user profiles, system/governance config, knowledge base, golden set"}],
      "authenticated": true,
      "properties": [{"name": "rules", "value": "firestore.rules — no client role self-elevation; admin-only config/system + knowledge_base reads"}]
    },
    {
      "name": "Lara Translate",
      "endpoints": ["https://api.laratranslate.com"],
      "x-trust-boundary": "backend-only egress; fails closed if creds absent"
    }
  ],
  "compositions": [
    {
      "aggregate": "incomplete",
      "assemblies": ["Safeguard LLM"],
      "properties": [
        {"name": "note", "value": "Third-party model weights and their training-data summaries are UNVERIFIED/opaque. Production auth, AWS Bedrock wiring, and bias testing are undocumented target-state."}
