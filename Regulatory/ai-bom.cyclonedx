    "component": {
      "type": "application",
      "name": "Safeguard LLM",
      "version": "2.5",
      "description": "Adversary-Aware Prompt Firewall & Forwarding Gateway (counter-spy). Secure GenAI control-plane that mediates all LLM interactions before inference (Shield-and-Sword pattern).",
      "properties": [
        {"name": "internalName", "value": "counter-spy"},
        {"name": "status", "value": "Beta"},
        {"name": "classification", "value": "Proprietary / AppSec Engineering"},
        {"name": "safeguardEffectivePrompt.sha256", "value": "590a286e60b99b0b353222b3ddaaa131db925a1f4d6222a0c3b1b3e49d203ad0"}
      ]
    },
    "authors": [{"name": "AppSec Engineering (Nate-Carroll-Cyber)"}],
    "properties": [
      {"name": "regulatory.euAiAct", "value": "High-risk / GPAI-adjacent (deployer duties, Annex IV, 10-yr retention)"},
      {"name": "regulatory.caAB2013", "value": "Applies to Golden Set/DPO + core seed corpus; third-party model data UNVERIFIED"},
      {"name": "regulatory.coSB24205", "value": "Conditional; language-based over-block = algorithmic-discrimination candidate"}
    ]
  },
  "components": [
