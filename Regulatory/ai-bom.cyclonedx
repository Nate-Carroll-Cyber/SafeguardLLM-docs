      "supplier": {"name": "Local (LM Studio host 192.168.0.183:1234)"},
      "properties": [
        {"name": "role", "value": "safeguard-judge"},
        {"name": "interface", "value": "OpenAI-compatible /v1/chat/completions"},
        {"name": "weights", "value": "third-party/local; UNVERIFIED (no checksum)"},
